{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "audiox",
  "version": "0.1.0",
  "identifier": "org.stormlightlabs.audiox",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": { "windows": [{ "title": "audiox", "width": 800, "height": 600 }], "security": { "csp": null } },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/whisper-cli", "binaries/ffmpeg", "binaries/yt-dlp"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
